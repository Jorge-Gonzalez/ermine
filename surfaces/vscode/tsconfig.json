{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "rootDir": ".",
    "outDir": "dist",
    "strict": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "types": ["vscode"]
  },
  "include": [
    "attributes.ts",
    "data.ts",
    "explain.ts",
    "extension.ts",
    "*.generated.json"
  ]
}
