{
  "compilerOptions": {
    "target": "ES2022",
    "module": "esnext",
    "moduleResolution": "bundler",
    "rootDir": "../..",
    "outDir": "dist",
    "strict": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "allowImportingTsExtensions": true,
    "skipLibCheck": true,
    "types": ["vscode", "node"]
  },
  "include": [
    "attributes.ts",
    "data.ts",
    "explain.ts",
    "extension.ts",
    "*.generated.json"
  ]
}
