{
  "name": "ermine",
  "publisher": "ermine",
  "displayName": "Ermine",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Generated Ermine completion and hover support",
  "main": "./dist/extension.js",
  "engines": {
    "vscode": "^1.121.0"
  },
  "activationEvents": [
    "onLanguage:html",
    "onLanguage:javascriptreact",
    "onLanguage:typescriptreact",
    "onLanguage:vue"
  ],
  "contributes": {
    "configuration": {
      "title": "Ermine",
      "properties": {
        "ermine.combinesFile": {
          "type": "string",
          "default": "ermine.combines",
          "description": "Workspace-relative Ermine combine definition file used by paragraph explanation."
        },
        "ermine.formatOnSave": {
          "type": "boolean",
          "default": false,
          "description": "Reorder Ermine class paragraphs into canonical order when a file is saved."
        },
        "ermine.paragraphLayout": {
          "type": "string",
          "enum": ["single-line", "plane-per-line"],
          "enumDescriptions": [
            "Keep the whole paragraph on one line.",
            "Give each plane (layout, layering, motion, state, skin) and each scope its own line."
          ],
          "default": "single-line",
          "description": "How the paragraph formatter lays out an ordered class paragraph."
        }
      }
    },
    "commands": [
      {
        "command": "ermine.explainClassParagraph",
        "title": "Ermine: Explain Class Paragraph"
      },
      {
        "command": "ermine.showClassParagraphGraph",
        "title": "Ermine: Show Class Paragraph Graph"
      },
      {
        "command": "ermine.formatClassParagraphs",
        "title": "Ermine: Format Class Paragraphs"
      }
    ]
  },
  "scripts": {
    "build": "node build.mjs",
    "check": "tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "@types/vscode": "^1.121.0",
    "esbuild": "^0.28.1",
    "typescript": "^6.0.3"
  }
}
