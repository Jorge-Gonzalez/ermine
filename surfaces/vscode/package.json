{
  "name": "@ermine/vscode",
  "displayName": "Ermine",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Generated Ermine completion and hover support",
  "main": "./dist/extension.js",
  "engines": {
    "vscode": "^1.121.0"
  },
  "activationEvents": [
    "onLanguage:html",
    "onLanguage:javascriptreact",
    "onLanguage:typescriptreact",
    "onLanguage:vue",
    "onCommand:ermine.explainClassParagraph"
  ],
  "contributes": {
    "commands": [
      {
        "command": "ermine.explainClassParagraph",
        "title": "Ermine: Explain Class Paragraph"
      }
    ]
  },
  "scripts": {
    "build": "node build.mjs",
    "check": "tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "@types/vscode": "^1.121.0",
    "esbuild": "^0.28.1",
    "typescript": "^6.0.3"
  }
}
