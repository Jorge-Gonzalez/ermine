# ── Dependencies ─────────────────────────────────────────────
node_modules/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ── Build / compile output ───────────────────────────────────
# Ermine compiles the grammar down to CSS + emits the derived
# spec; generated artifacts are reproducible from the registry,
# so they don't belong in version control.
dist/
build/
out/
lib/
*.tsbuildinfo
.tsbuildinfo

# Generated CSS (the compile target — derived from the registry)
# Keep this commented if you intend to commit a built stylesheet
# for consumers; uncomment to treat CSS as pure build output.
# *.css
# *.css.map

# ── Ermine build artifacts (reproducible from source) ────────
demo/ermine.generated.css

# ── Test / coverage ──────────────────────────────────────────
coverage/
*.lcov
.nyc_output/

# ── Logs & diagnostics ───────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ── Caches ───────────────────────────────────────────────────
.npm
.eslintcache
.cache/
.parcel-cache/
.vite/
.turbo/

# ── Environment / secrets ────────────────────────────────────
.env
.env.*
!.env.example

# ── Editors / IDE ────────────────────────────────────────────
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea/
*.swp
*.swo
*~

# ── OS cruft ─────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ── Scratch / local ──────────────────────────────────────────
# Local experiments and working notes that aren't part of the spec.
tmp/
temp/
scratch/
*.local
