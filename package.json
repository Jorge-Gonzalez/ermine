{
  "name": "ermine",
  "version": "0.1.0",
  "description": "Ermine is a structural abstraction layer — a style specification that CSS implements. A typed, composable grammar: orthogonal axes (structure, spacing, sizing, state…) compose without conflict, each owning disjoint CSS properties.",
  "keywords": [
    "css",
    "design-system",
    "style",
    "grammar",
    "linter",
    "composable",
    "abstraction-layer",
    "specification"
  ],
  "license": "MIT",
  "author": "Jorge",
  "type": "module",
  "packageManager": "pnpm@9.0.0",
  "files": [
    "src/registry.ts",
    "src/lint.ts",
    "src/emit.ts",
    "src/emitter-types.ts",
    "constitution",
    "src/ERMINE-SPEC.md",
    "src/ERMINE-GUIDE.md",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "docs:check": "tsx constitution/lint-docs.ts",
    "registry": "tsx src/registry.ts",
    "emit": "tsx src/emit.ts",
    "demo": "tsx demo/build.ts",
    "test": "node --import tsx --test test/*.test.ts",
    "test:browser": "node --import tsx --test test/browser/*.test.ts",
    "typecheck": "tsc --noEmit",
    "check": "npm run docs:check && npm run typecheck && npm run test"
  },
  "devDependencies": {
    "@types/node": "^26.0.1",
    "playwright": "^1.61.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=20"
  }
}
